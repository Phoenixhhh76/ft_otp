#!/usr/bin/env python3
"""Starter CLI for the ft_otp project."""

from __future__ import annotations

import argparse
import sys

from errors import FtOtpError
from otp_core import read_hex_key_file, totp
from storage import load_encrypted_key, save_encrypted_key


def build_parser() -> argparse.ArgumentParser:
    """Create the command-line interface expected by the subject."""

    parser = argparse.ArgumentParser(
        prog="ft_otp",
        description="Store a hex key (-g) or print a 6-digit OTP using HOTP with a time-based counter (-k).",
    )

    action_group = parser.add_mutually_exclusive_group(required=True)
    action_group.add_argument(
        "-g",
        metavar="HEX_KEY_FILE",
        help="read a hex key file and save it as encrypted ft_otp.key",
    )
    action_group.add_argument(
        "-k",
        metavar="ENCRYPTED_KEY_FILE",
        help="read the encrypted key file and print a 6-digit OTP",
    )

    return parser


def handle_generate_key(input_path: str) -> None:
    """Implement the `-g` flow."""

    secret = read_hex_key_file(input_path)
    save_encrypted_key(secret)
    print("Key was successfully saved in ft_otp.key.")


def handle_generate_otp(input_path: str) -> None:
    """Implement the `-k` flow."""

    secret = load_encrypted_key(input_path)
    print(totp(secret))


def main(argv: list[str] | None = None) -> int:
    """Parse arguments and dispatch the correct action."""

    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        if args.g:
            handle_generate_key(args.g)
        elif args.k:
            handle_generate_otp(args.k)
        else:
            parser.error("one action is required")
    except FileNotFoundError as exc:
        print(f"./ft_otp: error: file not found: {exc.filename}", file=sys.stderr)
        return 1
    except FtOtpError as exc:
        print(f"./ft_otp: error: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
